---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Content Disclaimer | Meteorite Jewelry by Johan"
  description="Important information about the content on meteorite.jewelry, including our use of AI-assisted content, how to report inaccuracies, and the limits of our liability."
>
  <Nav />

  <main class="disclaimer-page">
    <div class="container">

      <header class="dp-header">
        <p class="label">Legal Notice</p>
        <h1 class="serif dp-title">Content Disclaimer</h1>
        <p class="dp-sub">Please read this notice before relying on any information presented on this website.</p>
        <p class="dp-date">Last updated: March 2026</p>
      </header>

      <div class="dp-body">

        <section class="dp-section">
          <h2>1. AI-Assisted Content</h2>
          <p>
            Much of the written content on this website — including product descriptions,
            blog articles, educational guides, care instructions, material science
            explanations, and category descriptions — has been created with the assistance
            of artificial intelligence (AI) writing tools. While every effort is made to
            review and verify this content before publication, AI-generated text can
            contain errors, inaccuracies, outdated information, oversimplifications, or
            statements that do not accurately reflect current scientific consensus,
            industry practice, or the specific policies of Jewelry by Johan.
          </p>
          <p>
            This website is operated as an independent discovery and information resource.
            It is not the primary store for Jewelry by Johan. All purchases, order inquiries,
            and authoritative product information are handled exclusively at
            <a href="https://jewelrybyjohan.com" target="_blank" rel="noopener">jewelrybyjohan.com</a>.
          </p>
        </section>

        <section class="dp-section">
          <h2>2. No Warranty of Accuracy</h2>
          <p>
            The content on this website is provided for general informational and
            educational purposes only. We make no representations or warranties of any
            kind, express or implied, about the completeness, accuracy, reliability,
            suitability, or availability of any information, product descriptions,
            pricing references, care guidance, material specifications, or other content
            on this site.
          </p>
          <p>
            In particular, you should not rely solely on this website for:
          </p>
          <ul>
            <li>Final pricing — prices change and may differ on the main store</li>
            <li>Product availability — stock levels are not reflected here</li>
            <li>Scientific or gemological claims — always verify with authoritative sources</li>
            <li>Legal, medical, or financial guidance — none is offered or implied</li>
            <li>Care or maintenance instructions — verify with the main store before acting</li>
          </ul>
        </section>

        <section class="dp-section">
          <h2>3. Limitation of Liability</h2>
          <p>
            To the fullest extent permitted by applicable law, Jewelry by Johan and the
            operators of meteorite.jewelry shall not be liable for any loss, damage,
            cost, or expense of any kind — direct, indirect, incidental, consequential,
            or otherwise — arising from your reliance on any content published on this
            website, including but not limited to errors or omissions in product
            descriptions, care guides, material information, or blog articles, whether
            such content was created by humans or with the assistance of AI tools.
          </p>
          <p>
            Your use of this website and reliance on any content it contains is entirely
            at your own risk. Nothing on this site constitutes professional advice of
            any kind.
          </p>
        </section>

        <section class="dp-section">
          <h2>4. How to Report an Error</h2>
          <p>
            We take accuracy seriously. If you notice any content on this website that
            appears to be factually incorrect, misleading, outdated, or otherwise
            inaccurate — whether in a product description, blog article, care guide,
            or any other section — we ask that you report it to us before drawing any
            conclusions or taking any action based on it.
          </p>
          <p>
            We are committed to correcting genuine errors promptly. Please contact us
            at the address below with:
          </p>
          <ul>
            <li>The URL of the specific page containing the error</li>
            <li>A description of the content you believe to be inaccurate</li>
            <li>If possible, a reference or source supporting the correction</li>
          </ul>
          <p>
            We will review the reported content and make corrections as appropriate.
            By reporting an error rather than acting on it, you give us the opportunity
            to address it quickly and prevent others from being misled.
          </p>
          <div class="dp-contact-box">
            <p class="dp-contact-label">Report an inaccuracy:</p>
            <a href="https://jewelrybyjohan.com/pages/contact-us" target="_blank" rel="noopener" class="btn btn-primary">
              Contact Jewelry by Johan →
            </a>
            <a href="mailto:support@jewelrybyjohan.com" class="btn btn-outline">
              support@jewelrybyjohan.com
            </a>
          </div>
        </section>

        <section class="dp-section">
          <h2>5. Third-Party Links</h2>
          <p>
            This website contains links to external websites, including the main store
            at jewelrybyjohan.com and other third-party resources. We have no control
            over the content, policies, or accuracy of any external website and accept
            no responsibility for them. Linking to an external site does not constitute
            an endorsement of its content.
          </p>
        </section>

        <section class="dp-section">
          <h2>6. Content Updates</h2>
          <p>
            This website's content is updated periodically but not continuously.
            Information that was accurate at the time of publication may become
            outdated as products, policies, prices, and scientific understanding evolve.
            Always verify important decisions against the most current information
            available at <a href="https://jewelrybyjohan.com" target="_blank" rel="noopener">jewelrybyjohan.com</a>
            or by contacting the Jewelry by Johan team directly.
          </p>
        </section>

        <section class="dp-section">
          <h2>7. Governing Law</h2>
          <p>
            This disclaimer shall be governed by and construed in accordance with the
            laws of the State of Minnesota, United States. Any disputes arising in
            connection with this disclaimer or the content of this website shall be
            subject to the exclusive jurisdiction of the courts of Minnesota.
          </p>
        </section>

      </div>

      <div class="dp-footer-note">
        <p>
          This disclaimer applies only to <strong>meteorite.jewelry</strong> (this site).
          For the terms, policies, and warranties governing actual purchases, please refer
          to the official policies at
          <a href="https://jewelrybyjohan.com/policies/terms-of-service" target="_blank" rel="noopener">jewelrybyjohan.com</a>.
        </p>
      </div>

    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .disclaimer-page {
    padding-top: 100px;
    padding-bottom: 6rem;
    min-height: 70vh;
  }

  .dp-header {
    max-width: 700px;
    margin: 0 auto 4rem;
    text-align: center;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--c-border);
  }

  .dp-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    color: var(--c-text);
    margin: 0.5rem 0 1rem;
    line-height: 1.2;
  }

  .dp-sub {
    font-size: 1rem;
    color: var(--c-text-muted);
    line-height: 1.65;
    margin: 0 0 0.75rem;
  }

  .dp-date {
    font-size: 0.8125rem;
    color: var(--c-text-faint);
    margin: 0;
    font-family: var(--font-sans);
    letter-spacing: 0.04em;
  }

  .dp-body {
    max-width: 760px;
    margin: 0 auto;
  }

  .dp-section {
    margin-bottom: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--c-border);
  }

  .dp-section:last-child {
    border-bottom: none;
  }

  .dp-section h2 {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-gold);
    margin-bottom: 1.25rem;
  }

  .dp-section p {
    font-size: 0.9375rem;
    color: var(--c-text-muted);
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .dp-section p:last-child {
    margin-bottom: 0;
  }

  .dp-section ul {
    margin: 0.75rem 0 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .dp-section li {
    font-size: 0.9375rem;
    color: var(--c-text-muted);
    line-height: 1.65;
  }

  .dp-section a {
    color: var(--c-gold);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .dp-section a:hover { opacity: 0.8; }

  .dp-contact-box {
    margin-top: 1.75rem;
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .dp-contact-label {
    font-size: 0.8125rem;
    color: var(--c-text-faint);
    letter-spacing: 0.04em;
    margin: 0;
    width: 100%;
    font-family: var(--font-sans);
    text-transform: uppercase;
  }

  .dp-footer-note {
    max-width: 760px;
    margin: 3rem auto 0;
    padding: 1.5rem;
    background: var(--c-bg-2);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-md);
  }

  .dp-footer-note p {
    font-size: 0.875rem;
    color: var(--c-text-muted);
    line-height: 1.65;
    margin: 0;
  }

  .dp-footer-note a {
    color: var(--c-gold);
    text-decoration: none;
  }

  .dp-footer-note strong {
    color: var(--c-text);
  }
</style>