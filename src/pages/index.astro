---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ProductCard from '../components/ProductCard.astro';
import TrustBar from '../components/TrustBar.astro';
import { fetchProducts, getFeaturedProducts, getBestsellers, getCategoryProducts } from '../data/products';

const products = await fetchProducts();
const featured = getFeaturedProducts(products, 8);
const bestsellers = getBestsellers(products, 6);

const heroProduct   = featured[0];

const categories = [
  {
    href: '/rings',
    title: 'Meteorite Rings',
    sub: 'Wedding bands & engagement rings',
    icon: '○',
    count: getCategoryProducts(products, 'rings').length,
    gradient: 'linear-gradient(135deg, #0d0d14 0%, #1a1a28 100%)',
  },
  {
    href: '/earrings',
    title: 'Earrings',
    sub: 'Studs, drops & ear cuffs',
    icon: '◇',
    count: null,
    gradient: 'linear-gradient(135deg, #14101a 0%, #1f1428 100%)',
  },
  {
    href: '/pendants',
    title: 'Pendants & Necklaces',
    sub: 'Meteorite slice pendants & necklaces',
    icon: '▽',
    count: getCategoryProducts(products, 'pendants').length,
    gradient: 'linear-gradient(135deg, #0f1218 0%, #18202a 100%)',
  },
  {
    href: '/cufflinks',
    title: 'Cuff Links',
    sub: 'Meteorite cufflinks for every occasion',
    icon: '◈',
    count: getCategoryProducts(products, 'cufflinks').length,
    gradient: 'linear-gradient(135deg, #0d1014 0%, #181a28 100%)',
  },
  {
    href: '/tie-clips',
    title: 'Tie Clips',
    sub: 'Tie clips, tacks & bars',
    icon: '▬',
    count: getCategoryProducts(products, 'tie-clips').length,
    gradient: 'linear-gradient(135deg, #100d14 0%, #1a1428 100%)',
  },
  {
    href: '/unique',
    title: 'Unique Pieces',
    sub: 'One-of-a-kind sculptural pieces',
    icon: '✦',
    count: getCategoryProducts(products, 'unique').length,
    gradient: 'linear-gradient(135deg, #0d1210 0%, #182018 100%)',
  },
];
---

<BaseLayout
  title="Meteorite Jewelry by Johan | Authentic Gibeon Rings"
  description="Handcrafted Gibeon meteorite jewelry with iconic Widmanstätten patterns. Wedding rings, engagement bands, earrings, and pendants forged from 4.5 billion-year-old cosmic iron. USA-made."
>
  <Nav />

  <!-- ═══════════════════════════════════════
       HERO SECTION
  ═══════════════════════════════════════ -->
  <section class="hero" aria-labelledby="hero-heading">
    <!-- Animated background -->
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-glow hero-glow-1"></div>
      <div class="hero-glow hero-glow-2"></div>
      <div class="hero-stars" id="hero-stars"></div>
      <div class="crystal-lines"></div>
    </div>

    <div class="hero-inner">
      <!-- Left: Text -->
      <div class="hero-text">
        <p class="label hero-label">Authentic Gibeon Meteorite · USA Handcrafted</p>

        <h1 id="hero-heading" class="hero-heading">
          <span class="shimmer-text">Forged in</span>
          <br />
          <em class="hero-em serif">Cosmic Fire.</em>
          <br />
          <span class="hero-sub-heading">Worn for Eternity.</span>
        </h1>

        <p class="hero-body">
          Every piece carries a fragment of the ancient solar system —
          Gibeon meteorite with its unmistakable Widmanstätten crystal pattern,
          billions of years in the making, set by hand in Minneapolis.
        </p>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-num serif">4.5B</span>
            <span class="stat-label">Years in Formation</span>
          </div>
          <div class="stat-div"></div>
          <div class="stat">
            <span class="stat-num serif">∞</span>
            <span class="stat-label">Unique Patterns</span>
          </div>
          <div class="stat-div"></div>
          <div class="stat">
            <span class="stat-num serif">100%</span>
            <span class="stat-label">Handmade USA</span>
          </div>
        </div>

        <div class="hero-ctas">
          <a href="/rings" class="btn btn-primary hero-btn-primary">
            Explore the Collection
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="/about" class="btn btn-outline">Our Story</a>
        </div>

        <!-- Quick nav pills -->
        <div class="hero-pills">
          {['Rings', 'Ring Sets', 'Earrings', 'Pendants', 'Unique'].map(cat => (
            <a href={`/${cat.toLowerCase().replace(' ', '-')}`} class="pill">{cat}</a>
          ))}
        </div>
      </div>

      <!-- Right: Featured product showcase -->
      <div class="hero-visual">
        <div class="hero-ring-frame">
          {featured[0] && (
            <a
              href={`/products/${featured[0].handle}`}
              class="hero-ring-link"
              aria-label={`Featured: ${featured[0].title}`}
            >
              <div class="hero-ring-img-wrap shimmer-overlay">
                <img
                  src={featured[0].images[0]?.src}
                  alt={featured[0].images[0]?.alt || featured[0].title}
                  loading="eager"
                  decoding="async"
                  class="hero-ring-img"
                  width="600"
                  height="600"
                />
                <div class="hero-img-watermark" aria-hidden="true">Jewelry by Johan</div>
              </div>
              <div class="hero-ring-caption">
                <span class="label">Featured Piece</span>
                <span class="serif hero-ring-name">{featured[0].title}</span>
              </div>
            </a>
          )}
          <!-- Orbital decoration -->
          <div class="orbital orbit-1" aria-hidden="true"></div>
          <div class="orbital orbit-2" aria-hidden="true"></div>
          <div class="sparkle sp-1" aria-hidden="true"></div>
          <div class="sparkle sp-2" aria-hidden="true"></div>
          <div class="sparkle sp-3" aria-hidden="true"></div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="scroll-hint" aria-hidden="true">
      <div class="scroll-line"></div>
      <span>Scroll</span>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       TRUST BAR
  ═══════════════════════════════════════ -->
  <TrustBar />

  <!-- ═══════════════════════════════════════
       STORY INTRO
  ═══════════════════════════════════════ -->
  <section class="story-section section">
    <div class="container-sm">
      <div class="story-inner reveal">
        <p class="label" style="text-align:center;margin-bottom:1.5rem;">The Meteorite Story</p>
        <h2 class="story-heading serif">
          Before Earth existed,<br />
          <em>your ring was already forming.</em>
        </h2>
        <div class="story-divider"></div>
        <p class="story-body">
          Gibeon meteorite cooled at approximately 1°C per million years inside
          an ancient asteroid — so slowly that vast interlocking crystals of iron
          and nickel grew into geometric perfection. These are the Widmanstätten
          figures: cosmic fingerprints that no forge on Earth can recreate.
          Namibia's government now protects Gibeon as a national monument.
          The supply is finite. Your piece is singular.
        </p>
        <a href="/about" class="btn btn-outline" style="margin-top:2.5rem;">
          Read the Full Story →
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       CATEGORY GRID
  ═══════════════════════════════════════ -->
  <section class="categories-section section" aria-labelledby="categories-heading">
    <div class="container">
      <div class="section-header reveal">
        <p class="label">Collections</p>
        <h2 id="categories-heading">Explore by Category</h2>
        <p class="section-sub">Every form of cosmic adornment, forged from authentic Gibeon meteorite.</p>
      </div>

      <div class="categories-grid">
        {categories.map((cat, i) => (
          <a
            href={cat.href}
            class="cat-card reveal"
            style={`animation-delay: ${i * 0.1}s; background: ${cat.gradient};`}
          >
            <div class="cat-icon" aria-hidden="true">{cat.icon}</div>
            <div class="cat-body">
              <h3 class="cat-title serif">{cat.title}</h3>
              <p class="cat-sub">{cat.sub}</p>
              {cat.count && (
                <span class="cat-count">{cat.count} pieces</span>
              )}
            </div>
            <div class="cat-arrow" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
            <div class="cat-shimmer" aria-hidden="true"></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       BESTSELLERS
  ═══════════════════════════════════════ -->
  <section class="bestsellers-section section" aria-labelledby="bestsellers-heading">
    <div class="container">
      <div class="section-header reveal">
        <p class="label">Most Loved</p>
        <h2 id="bestsellers-heading">Customer Favorites</h2>
        <p class="section-sub">The pieces our couples wear every day — from wedding day to eternity.</p>
      </div>

      <div class="products-grid">
        {bestsellers.map((product, i) => (
          <div class="reveal" style={`animation-delay: ${i * 0.08}s`}>
            <ProductCard product={product} featured={i === 0} />
          </div>
        ))}
      </div>

      <div class="section-cta reveal">
        <a href="/rings" class="btn btn-outline">View All Rings →</a>
        <a href="https://jewelrybyjohan.com" target="_blank" rel="noopener" class="btn btn-primary">
          Explore Full Collection
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       BEHIND THE PIECE — Lore Sections
  ═══════════════════════════════════════ -->
  <section class="lore-section" aria-labelledby="lore-heading">
    <div class="container">
      <div class="lore-grid">

        <!-- Lore 1: The Pattern -->
        <div class="lore-card reveal">
          <div class="lore-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <path d="M20 4 L36 20 L20 36 L4 20 Z" stroke="currentColor" stroke-width="1" opacity="0.4"/>
              <path d="M20 10 L30 20 L20 30 L10 20 Z" stroke="currentColor" stroke-width="1.5" opacity="0.7"/>
              <circle cx="20" cy="20" r="3" fill="currentColor"/>
              <path d="M20 10 L20 4M20 36 L20 30M10 20 L4 20M36 20 L30 20" stroke="currentColor" stroke-width="0.75" opacity="0.3"/>
            </svg>
          </div>
          <h3 class="lore-title serif">The Widmanstätten Pattern</h3>
          <p class="lore-body">
            Cooling at 1°C per million years, iron-nickel crystals grew into
            interlocking geometric formations unlike anything produced on Earth.
            Etched with acid, these ancient figures emerge like stars drawn in metal.
          </p>
          <a href="/blog/cosmic-origins-of-gibeon-meteorite" class="lore-link">
            Learn the science →
          </a>
        </div>

        <!-- Lore 2: The Origin -->
        <div class="lore-card reveal" style="animation-delay:0.1s">
          <div class="lore-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <circle cx="20" cy="20" r="15" stroke="currentColor" stroke-width="1" opacity="0.3"/>
              <circle cx="20" cy="20" r="9" stroke="currentColor" stroke-width="1.5" opacity="0.6"/>
              <circle cx="20" cy="20" r="3" fill="currentColor"/>
              <path d="M5 20 A15 15 0 0 1 35 20" stroke="currentColor" stroke-width="0.75" stroke-dasharray="2 3" opacity="0.4"/>
            </svg>
          </div>
          <h3 class="lore-title serif">4.5 Billion Years Old</h3>
          <p class="lore-body">
            Before Earth formed, the parent asteroid of Gibeon meteorite drifted
            through space. It fell near Gibeon, Namibia approximately 30,000 years
            ago — long before the first human civilization. It has been waiting for you.
          </p>
          <a href="/about" class="lore-link">
            Our full origin story →
          </a>
        </div>

        <!-- Lore 3: No Two Alike -->
        <div class="lore-card reveal" style="animation-delay:0.2s">
          <div class="lore-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <path d="M20 4 L26 14 L38 14 L29 21 L32 33 L20 26 L8 33 L11 21 L2 14 L14 14 Z"
                stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.7"/>
              <path d="M20 10 L23 17 L30 17 L25 21 L27 28 L20 24 L13 28 L15 21 L10 17 L17 17 Z"
                fill="currentColor" opacity="0.15"/>
            </svg>
          </div>
          <h3 class="lore-title serif">Utterly Singular</h3>
          <p class="lore-body">
            Every meteorite inlay is cut from a unique fragment. Your ring's
            Widmanstätten pattern has never appeared on any other piece and
            never will. No duplicates. No mass production. One cosmos, one ring.
          </p>
          <a href="/sizing-guide" class="lore-link">
            Start designing yours →
          </a>
        </div>

        <!-- Lore 4: Protected -->
        <div class="lore-card reveal" style="animation-delay:0.3s">
          <div class="lore-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <path d="M20 4 L34 10 L34 22 C34 30 20 36 20 36 C20 36 6 30 6 22 L6 10 Z"
                stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.7"/>
              <path d="M14 20 L18 24 L26 16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <h3 class="lore-title serif">Protected & Finite</h3>
          <p class="lore-body">
            Since 2004, Namibia has declared Gibeon meteorite a protected national
            monument. No new collection is permitted. The supply in circulation is
            all that exists. When it's gone, it's gone — forever.
          </p>
          <a href="/blog/why-meteorite-makes-the-best-wedding-band" class="lore-link">
            Why this matters →
          </a>
        </div>

        <!-- Lore 5: USA Craft -->
        <div class="lore-card reveal" style="animation-delay:0.4s">
          <div class="lore-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <path d="M20 6 C13 6 7 11 7 20 C7 29 13 34 20 34 C27 34 33 29 33 20 C33 11 27 6 20 6"
                stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
              <path d="M12 20 L20 12 L28 20" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <circle cx="20" cy="24" r="2" fill="currentColor"/>
            </svg>
          </div>
          <h3 class="lore-title serif">Handmade in Minneapolis</h3>
          <p class="lore-body">
            Johan shapes, cuts, etches, inlays, and polishes every single piece
            by hand in the USA. No factory. No offshore shortcuts. Each ring
            carries hours of skilled artisan work alongside billions of years of cosmic formation.
          </p>
          <a href="/about" class="lore-link">
            Meet the maker →
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       FEATURED GRID (More Products)
  ═══════════════════════════════════════ -->
  <section class="featured-section section" aria-labelledby="featured-heading">
    <div class="container">
      <div class="section-header reveal">
        <p class="label">The Collection</p>
        <h2 id="featured-heading">Every Piece, One of a Kind</h2>
        <p class="section-sub">Browse the full range of meteorite jewelry — from bold men's bands to sculptural engagement rings.</p>
      </div>

      <div class="products-grid">
        {featured.slice(2, 8).map((product, i) => (
          <div class="reveal" style={`animation-delay: ${i * 0.07}s`}>
            <ProductCard product={product} />
          </div>
        ))}
      </div>

      <div class="section-cta reveal">
        <a href="/rings" class="btn btn-primary">View All Rings →</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       SOCIAL PROOF / REVIEWS
  ═══════════════════════════════════════ -->
  <section class="reviews-section section" aria-labelledby="reviews-heading">
    <div class="container">
      <div class="section-header reveal">
        <p class="label">Customer Stories</p>
        <h2 id="reviews-heading">What Our Couples Say</h2>
      </div>

      <div class="reviews-grid">
        {[
          {
            quote: "The Widmanstätten pattern on my husband's band is unlike anything I've ever seen. He gets compliments every single day. Worth every penny.",
            name: "Sarah M.",
            ring: "Gibeon Meteorite Titanium Band",
            stars: 5,
          },
          {
            quote: "I wanted something that felt as significant as the commitment. A billion-year-old piece of the solar system on my finger — that's it. That's the feeling.",
            name: "Marcus T.",
            ring: "Meteorite & Yellow Gold Wedding Band",
            stars: 5,
          },
          {
            quote: "Johan was patient, thoughtful, and the craftsmanship is extraordinary. The ring arrived perfectly — I cried when I opened the box.",
            name: "Elena & James K.",
            ring: "Meteorite Engagement Ring Set",
            stars: 5,
          },
        ].map((r, i) => (
          <div class="review-card reveal" style={`animation-delay: ${i * 0.1}s`}>
            <div class="review-stars" aria-label={`${r.stars} out of 5 stars`}>
              {'★'.repeat(r.stars)}
            </div>
            <blockquote class="review-quote serif">"{r.quote}"</blockquote>
            <div class="review-author">
              <span class="review-name">{r.name}</span>
              <span class="review-ring">{r.ring}</span>
            </div>
          </div>
        ))}
      </div>

      <div class="reviews-note reveal">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/>
        </svg>
        <span>Thousands of verified reviews on <a href="https://jewelrybyjohan.com" target="_blank" rel="noopener">Jewelry by Johan →</a></span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       FINAL CTA BANNER
  ═══════════════════════════════════════ -->
  <section class="cta-banner">
    <div class="cta-bg" aria-hidden="true">
      <div class="cta-glow"></div>
    </div>
    <div class="container">
      <div class="cta-inner reveal">
        <p class="label">Begin Your Journey</p>
        <h2 class="serif cta-heading">
          Your ring is waiting<br />
          <em>in the cosmos.</em>
        </h2>
        <p class="cta-sub">
          Every piece is made to order. Customized to your size, your metal,
          your vision. Start exploring today — complete your order at
          JewelryByJohan.com, where every purchase is fulfilled.
        </p>
        <div class="cta-actions">
          <a
            href="https://jewelrybyjohan.com"
            target="_blank"
            rel="noopener"
            class="btn btn-primary cta-btn"
          >
            Order at Jewelry by Johan
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="/sizing-guide" class="btn btn-outline">Find Your Ring Size</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ──────── HERO ──────── */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    padding-top: 68px; /* nav height */
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .hero-glow-1 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(201,144,31,0.08) 0%, transparent 70%);
    top: -100px;
    right: -100px;
    animation: heroGlow1 8s ease-in-out infinite;
  }

  .hero-glow-2 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(124,106,255,0.05) 0%, transparent 70%);
    bottom: 100px;
    left: 0;
    animation: heroGlow2 10s ease-in-out infinite;
  }

  @keyframes heroGlow1 {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.7; }
    50% { transform: translate(30px, 20px) scale(1.1); opacity: 1; }
  }

  @keyframes heroGlow2 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-20px, 30px); }
  }

  /* Star field */
  .hero-stars {
    position: absolute;
    inset: 0;
  }

  /* Crystal lines (Widmanstätten decorative) */
  .crystal-lines {
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(
        15deg, transparent, transparent 60px,
        rgba(201,144,31,0.025) 60px, rgba(201,144,31,0.025) 61px
      ),
      repeating-linear-gradient(
        -15deg, transparent, transparent 80px,
        rgba(200,205,214,0.02) 80px, rgba(200,205,214,0.02) 81px
      );
  }

  .hero-inner {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
    max-width: 1440px;
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 7rem) clamp(1.5rem, 5vw, 4rem);
    position: relative;
    z-index: 1;
  }

  /* Text */
  .hero-label {
    margin-bottom: 1.5rem;
  }

  .hero-heading {
    font-size: clamp(2.8rem, 6.5vw, 6.5rem);
    font-weight: 300;
    line-height: 1.0;
    letter-spacing: -0.025em;
    margin-bottom: 1.5rem;
    color: var(--c-text);
  }

  .hero-em {
    font-style: italic;
    color: var(--c-text);
    font-weight: 300;
  }

  .hero-sub-heading {
    display: block;
    font-weight: 600;
    font-style: normal;
    letter-spacing: -0.01em;
  }

  .hero-body {
    font-size: 1.125rem;
    color: var(--c-text-muted);
    max-width: 480px;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .stat-num {
    display: block;
    font-size: 1.75rem;
    font-weight: 400;
    color: var(--c-text);
    line-height: 1;
  }

  .stat-label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-text-muted);
    margin-top: 3px;
  }

  .stat-div {
    width: 1px;
    height: 40px;
    background: var(--c-border);
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
