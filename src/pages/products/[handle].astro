---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import ProductCard from '../../components/ProductCard.astro';
import {
  fetchProducts,
  getMinPrice,
  getMaxPrice,
  getMaterials,
  getRelatedProducts,
  stripHtml,
  truncateText,
  productUrl,
  MAIN_STORE,
} from '../../data/products';
import type { Product } from '../../types/product';

export async function getStaticPaths() {
  const products = await fetchProducts();
  return products.map((p) => ({
    params: { handle: p.handle },
    props: { product: p, allProducts: products },
  }));
}

interface Props {
  product: Product;
  allProducts: Product[];
}

const { product, allProducts } = Astro.props;
const related = getRelatedProducts(allProducts, product, 4);
const shopUrl = productUrl(product.handle);
const minPrice = getMinPrice(product);
const maxPrice = getMaxPrice(product);

const materials = getMaterials(product);
const plainDesc = stripHtml(product.body_html);
const metaDesc = truncateText(plainDesc, 160);
const isMimetic = product.title.toLowerCase().includes('mimetic') || product.body_html.toLowerCase().includes('mimetic');

// Determine which collection this product belongs to (for breadcrumb)
function getCollectionLink(p: typeof product): { href: string; label: string } {
  const type = p.product_type.toLowerCase();
  const tags = p.tags.toLowerCase();
  if (type.includes('earring') || tags.includes('earring')) return { href: '/earrings', label: 'Earrings' };
  if (type.includes('pendant') || type.includes('necklace') || tags.includes('pendant') || tags.includes('necklace')) return { href: '/pendants', label: 'Pendants' };
  if (type.includes('cufflink') || type.includes('cuff link') || tags.includes('cufflink') || tags.includes('cuff link')) return { href: '/cufflinks', label: 'Cuff Links' };
  if (type.includes('tie clip') || type.includes('tie tack') || type.includes('tie bar') || tags.includes('tie clip') || tags.includes('tie tack') || tags.includes('tie bar')) return { href: '/tie-clips', label: 'Tie Clips' };
  if (type === 'ring sets' || tags.includes('ring-sets') || tags.includes('ring sets')) return { href: '/ring-sets', label: 'Ring Sets' };
  return { href: '/rings', label: 'Rings' };
}
const collection = getCollectionLink(product);

// Only rings cannot be resized — don't show that note on other product types
const isRing = product.product_type === 'Rings';

// Build tag array for display
const tagArr = product.tags
  .split(',')
  .map((t) => t.trim())
  .filter((t) =>
    ['meteorite', 'titanium', 'yellow-gold', 'white-gold', 'rose-gold', 'diamond',
     'moissanite', 'sapphire', 'dinosaur-bone', 'whiskey barrel', 'flat-profile',
     'round-profile', 'polished-finish', 'brushed', 'engagement-rings', 'wedding-bands',
     'ring-sets', 'solitaire', '4mm', '6mm', '8mm', '10mm'].includes(t.toLowerCase())
  )
  .slice(0, 8);

// Schema.org Product JSON-LD
const productSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.title,
  description: metaDesc,
  image: product.images.map((i) => i.src),
  brand: { '@type': 'Brand', name: 'Jewelry by Johan' },
  url: `https://meteorite.jewelry/products/${product.handle}`,
  sameAs: shopUrl,
  manufacturer: {
    '@type': 'Organization',
    name: 'Jewelry by Johan',
    url: 'https://jewelrybyjohan.com',
  },
};

// BreadcrumbList JSON-LD for Google rich results
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://meteorite.jewelry/' },
    { '@type': 'ListItem', position: 2, name: collection.label, item: `https://meteorite.jewelry${collection.href}` },
    { '@type': 'ListItem', position: 3, name: product.title, item: `https://meteorite.jewelry/products/${product.handle}` },
  ],
};
---

<BaseLayout
  title={`${product.title} | Meteorite Jewelry by Johan`}
  description={metaDesc}
  image={product.images[0]?.src}
  type="product"
  canonicalUrl={shopUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />
  <Nav />

  <main class="product-page" itemscope itemtype="https://schema.org/Product">
    <meta itemprop="name" content={product.title} />
    <meta itemprop="description" content={metaDesc} />

    <!-- ────────── BREADCRUMB ────────── -->
    <nav class="product-breadcrumb container" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <a href={collection.href}>{collection.label}</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">{product.title}</span>
    </nav>

    <!-- ────────── HERO SPLIT ────────── -->
    <section class="product-hero container">
      <!-- LEFT: Image Gallery -->
      <div class="gallery" id="gallery">
        <!-- Main image -->
        <div class="gallery-main shimmer-overlay" id="gallery-main">
          <img
            src={product.images[0]?.src}
            alt={product.images[0]?.alt || product.title}
            loading="eager"
            decoding="async"
            class="gallery-main-img"
            id="main-img"
            width="800"
            height="800"
            itemprop="image"
          />
          <!-- Zoom hint -->
          <div class="zoom-hint" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
              <line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/>
            </svg>
            Click to enlarge
          </div>
          <!-- Watermark -->
          <div class="gallery-watermark" aria-hidden="true">Jewelry by Johan</div>
          <!-- Authentic badge — hidden on Mimetic products -->
          {!isMimetic && (
            <div class="auth-badge" aria-label="Authentic Gibeon Meteorite">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/>
              </svg>
              Authentic Gibeon Meteorite
            </div>
          )}
        </div>

        <!-- Thumbnails -->
        {product.images.length > 1 && (
          <div class="gallery-thumbs" id="gallery-thumbs" role="list">
            {product.images.map((img, i) => (
              <button
                class={`thumb-btn ${i === 0 ? 'active' : ''}`}
                data-src={img.src}
                data-alt={img.alt || product.title}
                aria-label={`View image ${i + 1}: ${img.alt || product.title}`}
                role="listitem"
              >
                <img
                  src={img.src}
                  alt={img.alt || product.title}
                  loading="lazy"
                  decoding="async"
                  width="120"
                  height="120"
                />
                <span class="thumb-watermark" aria-hidden="true">JbJ</span>
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- RIGHT: Product Info -->
      <div class="product-info">
        <!-- Meta tags -->
        <div class="product-meta">
          <span class="label">{product.product_type}</span>
          {tagArr.slice(0, 3).map((t) => (
            <span class="meta-tag">{t.replace(/-/g, ' ')}</span>
          ))}
        </div>

        <h1 class="product-title serif" itemprop="name">{product.title}</h1>

        <div class="product-divider"></div>

        <!-- Materials -->
        {materials.length > 0 && (
          <div class="materials-block">
            <p class="block-label">Materials</p>
            <div class="materials-list">
              {materials.map((m) => (
                <span class="material-chip">{m}</span>
              ))}
            </div>
          </div>
        )}

        <!-- Sizing info -->
        <div class="size-info-block">
          <a href="/sizing-guide" class="size-guide-link">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/>
            </svg>
            Ring Sizing Guide
          </a>
          <p class="size-hint">Not sure of your size? A sizer set is included with your purchase, or <a href="https://jewelrybyjohan.com/products/ring-sizer-custom-made-1170" target="_blank" rel="noopener" style="color:var(--c-gold);text-decoration:none;">order a custom made ring sizer for $10</a>. Be sure to select the same width as the ring you want — a wide ring fits tighter than a thin ring in the same size.</p>
        </div>

        <div class="product-divider"></div>

        <!-- CTAs -->
        <div class="product-ctas">
          <a
            href={shopUrl}
            target="_blank"
            rel="noopener"
            class="btn btn-primary cta-main"
            aria-label={`Order ${product.title} at Jewelry by Johan`}
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 01-8 0"/>
            </svg>
            Order on Jewelry by Johan
          </a>
          <a
            href={`${MAIN_STORE}/pages/contact-us?product=${product.handle}`}
            target="_blank"
            rel="noopener"
            class="btn btn-outline"
          >
            Ask a Question
          </a>
        </div>

        <!-- Redirect notice -->
        <div class="redirect-notice">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/>
          </svg>
          Checkout, customization, and payment are completed securely on
          <a href="https://jewelrybyjohan.com" target="_blank" rel="noopener">jewelrybyjohan.com</a>
        </div>

        <!-- Trust signals -->
        <div class="product-trust">
          {[
            ['Free laser engraving', '✍'],
            ['30-day returns', '✓'],
            ['Handmade in USA', '★'],
            ...(!isMimetic ? [['Authentic meteorite', '◆']] : []),
          ].map(([text, icon]) => (
            <div class="pt-item">
              <span class="pt-icon">{icon}</span>
              <span>{text}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ────────── PRODUCT DETAILS TABS ────────── -->
    <section class="details-section container">
      <div class="tabs-nav" role="tablist">
        <button class="tab-btn active" role="tab" aria-selected="true" aria-controls="tab-description" id="btn-description">
          Description
        </button>
        <button class="tab-btn" role="tab" aria-selected="false" aria-controls="tab-specs" id="btn-specs">
          Ring Specs
        </button>
        <button class="tab-btn" role="tab" aria-selected="false" aria-controls="tab-care" id="btn-care">
          Meteorite Care
        </button>
        <button class="tab-btn" role="tab" aria-selected="false" aria-controls="tab-shipping" id="btn-shipping">
          Shipping & Returns
        </button>
      </div>

      <!-- Description -->
      <div class="tab-panel active" id="tab-description" role="tabpanel" aria-labelledby="btn-description">
        <div class="tab-content-grid">
          <div class="prose tab-prose" set:html={product.body_html} />
          <div class="tab-aside">
            <div class="aside-card">
              <p class="label" style="margin-bottom:1rem">Behind the Piece</p>
              <p class="aside-text">
                This piece is cut and set entirely by hand by Johan in Minneapolis, USA.
                The Gibeon meteorite inlay is etched with acid to reveal its unique
                Widmanstätten crystal pattern — a formation that took millions of years
                at approximately 1°C per million years of cooling.
              </p>
              <p class="aside-text" style="margin-top:1rem">
                No two rings will ever share the same pattern. Yours is singular,
                permanent, and genuinely cosmic.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Specs -->
      <div class="tab-panel" id="tab-specs" role="tabpanel" aria-labelledby="btn-specs" hidden>
        <div class="specs-grid">
          {[
            ['Product Type', product.product_type],
            ['Vendor', product.vendor],
            ['Materials', materials.join(', ') || 'See description'],
            ['Available Sizes', 'Custom — select at checkout'],
            ['Origin', 'Handmade in USA'],
            ['Meteorite Source', 'Gibeon, Namibia'],
            ['Meteorite Age', '~4.5 billion years'],
          ].map(([label, value]) => (
            <div class="spec-row">
              <dt class="spec-label">{label}</dt>
              <dd class="spec-value">{value}</dd>
            </div>
          ))}
        </div>
      </div>

      <!-- Care -->
      <div class="tab-panel" id="tab-care" role="tabpanel" aria-labelledby="btn-care" hidden>
        <div class="care-grid">
          {[
            {
              icon: '💧',
              title: 'Avoid Prolonged Moisture',
              body: 'Brief water exposure (hand-washing, light rain) is fine. Remove before swimming in saltwater or chlorinated pools.',
            },
            {
              icon: '🧴',
              title: 'No Harsh Chemicals',
              body: 'Keep away from cleaning products, bleach, solvents, and acids. Remove your ring before household cleaning.',
            },
            {
              icon: '✨',
              title: 'Monthly Cleaning',
              body: 'Rinse under cool water, dry immediately with a soft cloth. Apply a drop of mineral oil or Renaissance Wax monthly.',
            },
            {
              icon: '🔄',
              title: 'Re-Etching Available',
              body: 'Over years of wear, the Widmanstätten pattern may soften. Send it back to Johan for a fresh acid etch to restore its full drama.',
            },
            {
              icon: '📦',
              title: 'Storage',
              body: 'Store in a dry environment. A silica gel packet in your jewelry box will absorb ambient moisture.',
            },
            {
              icon: '🔧',
              title: 'Lifetime Support',
              body: 'Johan stands behind every piece. Contact us any time for structural issues, re-etching, Ring Armor repair, or warranty questions.',
            },
          ].map((c) => (
            <div class="care-card">
              <span class="care-icon" aria-hidden="true">{c.icon}</span>
              <h4 class="care-title">{c.title}</h4>
              <p class="care-body">{c.body}</p>
            </div>
          ))}
        </div>
        <div class="care-cta">
          <a href="/blog/caring-for-meteorite-rings" class="btn btn-outline">
            Read Full Care Guide →
          </a>
        </div>
      </div>

      <!-- Shipping -->
      <div class="tab-panel" id="tab-shipping" role="tabpanel" aria-labelledby="btn-shipping" hidden>
        <div class="shipping-grid">
          <div class="shipping-block">
            <h3 class="serif">Production & Shipping</h3>
            <div class="shipping-items">
              {[
                ['Production time', '2–4 weeks (handmade to order)'],
                ['US shipping', 'Free on orders over $500'],
                ['International', 'Available — rates calculated at checkout'],
                ['Packaging', 'Premium gift box, certificate of authenticity'],
                ['Insurance', 'All shipments fully insured'],
              ].map(([label, value]) => (
                <div class="shipping-row">
                  <span class="ship-label">{label}</span>
                  <span class="ship-value">{value}</span>
                </div>
              ))}
            </div>
          </div>
          <div class="shipping-block">
            <h3 class="serif">Services & Warranty</h3>
            <div class="shipping-items">
              {[
                ['Laser engraving', 'Free — up to 25 characters, choice of fonts'],
                ['Meteorite protection', 'Free lifetime cleaning & re-etching — you pay shipping to us'],
                ['Ring Armor repair', 'Free lifetime repair of antler, wood & crushed material sealing'],
                ...(isRing ? [['Cannot be resized', 'Our meteorite inlay rings cannot be resized after production — size carefully']] : []),
              ].map(([label, value]) => (
                <div class="shipping-row">
                  <span class="ship-label">{label}</span>
                  <span class="ship-value">{value}</span>
                </div>
              ))}
            </div>
            <div style="margin-top:1.25rem;display:flex;flex-direction:column;gap:.5rem;">
              <a href="https://jewelrybyjohan.com/pages/faqs" target="_blank" rel="noopener" class="ship-link">FAQ — engraving, sizing & more →</a>
              <a href="https://jewelrybyjohan.com/pages/returns" target="_blank" rel="noopener" class="ship-link">RGA Requests & Returns →</a>
            </div>
          </div>
          <div class="shipping-block">
            <h3 class="serif">Return Policy</h3>
            <div class="shipping-items">
              {[
                ['Return window', '30 days from delivery — in-store credit issued'],
                ['Condition', 'Normal wear considered based on time owned'],
                ['Wrong size ordered', '50% remake fee; original ring returned within 30 days required'],
                ['Custom ring sizer', 'If sizer fit and ring arrives wrong size, we remake at no cost (one time)'],
                ['Cancel window', '3 business days from order confirmation for full refund'],
                ['After cancel window', '50% refund as in-store credit'],
                ['Engraving defects', 'Covered under return policy if error is ours'],
                ['Warranty void if', 'Ring taken to another jeweler for any alteration'],
              ].map(([label, value]) => (
                <div class="shipping-row">
                  <span class="ship-label">{label}</span>
                  <span class="ship-value">{value}</span>
                </div>
              ))}
            </div>
            <p class="ship-note">Our policy reflects the custom, handmade nature of every piece. We are not responsible for acts of God, misuse, or abuse. We highly recommend adding your ring to your homeowner's insurance (typically 1–2% of value annually) or insuring through <a href="https://www.jewelersmutual.com" target="_blank" rel="noopener">Jeweler's Mutual</a>.</p>
          </div>
        </div>
        <div class="care-cta">
          <a href={shopUrl} target="_blank" rel="noopener" class="btn btn-primary">
            Order Securely on Jewelry by Johan →
          </a>
        </div>
      </div>
    </section>

    <!-- ────────── RELATED PRODUCTS ────────── -->
    {related.length > 0 && (
      <section class="related-section section container">
        <div class="section-header-left">
          <p class="label">You May Also Love</p>
          <h2 class="serif">Related Pieces</h2>
        </div>
        <div class="related-grid">
          {related.map((p, i) => (
            <div class="reveal" style={`animation-delay:${i * 0.08}s`}>
              <ProductCard product={p} />
            </div>
          ))}
        </div>
      </section>
    )}
  </main>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Image lightbox" hidden>
    <button class="lightbox-close" id="lightbox-close" aria-label="Close lightbox">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </button>
    <div class="lightbox-img-wrap">
      <img src="" alt="" class="lightbox-img" id="lightbox-img" />
      <div class="lightbox-watermark" aria-hidden="true">Jewelry by Johan</div>
    </div>
  </div>

  <Footer />
</main>

<style>
  /* ── PAGE ── */
  .product-page { padding-top: 68px; }

  .product-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--c-text-muted);
    padding-top: 2rem;
    padding-bottom: 0;
    flex-wrap: wrap;
  }

  .product-breadcrumb a { color: var(--c-text-muted); transition: color .2s; }
  .product-breadcrumb a:hover { color: var(--c-gold); }

  /* ── HERO SPLIT ── */
  .product-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2.5rem, 5vw, 5rem);
    padding-top: 2.5rem;
    padding-bottom: 4rem;
    align-items: start;
  }

  /* ── GALLERY ── */
  .gallery { display: flex; flex-direction: column; gap: 1rem; position: sticky; top: 88px; }

  .gallery-main {
    position: relative;
    aspect-ratio: 1/1;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--c-bg-2);
    border: 1px solid var(--c-border);
    cursor: zoom-in;
    transition: border-color .4s;
  }

  .gallery-main:hover { border-color: var(--c-border-gold); }

  .gallery-main-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .6s var(--ease-smooth);
  }

  .gallery-main:hover .gallery-main-img { transform: scale(1.03); }

  .zoom-hint {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    display: flex;
    align-items: center;
    gap: .375rem;
    font-size: .6875rem;
    letter-spacing: .06em;
    color: rgba(255,255,255,.7);
    background: rgba(10,10,15,.6);
    padding: .375rem .75rem;
    border-radius: var(--radius-full);
    backdrop-filter: blur(8px);
    opacity: 0;
    transition: opacity .3s;
    pointer-events: none;
  }

  .gallery-main:hover .zoom-hint { opacity: 1; }

  .auth-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    display: flex;
    align-items: center;
    gap: .375rem;
    font-size: .625rem;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--c-gold-light);
    background: rgba(10,10,15,.75);
    border: 1px solid rgba(201,144,31,.3);
    padding: .35rem .75rem;
    border-radius: var(--radius-full);
    backdrop-filter: blur(8px);
  }

  .gallery-watermark {
    position: absolute;
    bottom: 0.75rem;
    right: 0.875rem;
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    pointer-events: none;
    user-select: none;
    z-index: 3;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.8);
  }

  .gallery-thumbs {
    display: flex;
    gap: .625rem;
    flex-wrap: wrap;
  }

  .thumb-btn {
    width: 72px;
    height: 72px;
    border-radius: var(--radius);
    overflow: hidden;
    border: 2px solid var(--c-border);
    background: var(--c-bg-2);
    cursor: pointer;
    padding: 0;
    transition: border-color .2s, transform .2s var(--ease-bounce);
    flex-shrink: 0;
  }

  .thumb-btn:hover { transform: scale(1.05); border-color: var(--c-border-gold); }
  .thumb-btn.active { border-color: var(--c-gold); }

  .thumb-btn img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── PRODUCT INFO ── */
  .product-info { padding-top: .5rem; }

  .product-meta {
    display: flex;
    align-items: center;
    gap: .5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .meta-tag {
    font-size: .625rem;
    font-weight: 500;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--c-text-muted);
    background: var(--c-bg-3);
    padding: .2rem .6rem;
    border-radius: var(--radius-sm);
  }

  .product-title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 300;
    color: var(--c-text);
    line-height: 1.2;
    margin-bottom: 1.25rem;
  }

  .product-divider {
    height: 1px;
    background: linear-gradient(90deg, var(--c-border-gold), transparent);
