---
export interface Props {
  title: string;
  description: string;
  image?: string;
  type?: string;
  canonicalUrl?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  image = '/og-default.svg',
  type = 'website',
  canonicalUrl,
  noindex = false,
} = Astro.props;

const canonical = canonicalUrl || new URL(Astro.url.pathname, Astro.site).href;
const fullTitle = title.includes('Meteorite') ? title : `${title} | Meteorite Jewelry by Johan`;
---

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <!-- Primary Meta -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Open Graph -->
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={image} />
  <meta property="og:site_name" content="Meteorite Jewelry by Johan" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image} />

  <!-- Favicon + PWA -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#0a0a0f" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <!-- Async font load — prevents render-blocking (saves ~2,100ms FCP on mobile) -->
  <link
    rel="preload"
    as="style"
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300;1,9..40,400&display=swap"
    onload="this.onload=null;this.rel='stylesheet'"
  />
  <noscript>
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300;1,9..40,400&display=swap"
      rel="stylesheet"
    />
  </noscript>

  <!-- Schema.org Organization -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Jewelry by Johan",
    "url": "https://meteorite.jewelry",
    "sameAs": ["https://jewelrybyjohan.com"],
    "logo": "https://meteorite.jewelry/favicon.svg",
    "description": "Handcrafted meteorite jewelry featuring authentic Gibeon meteorite with Widmanstätten patterns. Wedding bands, engagement rings, pendants and more.",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "US"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "customer service",
      "url": "https://jewelrybyjohan.com/pages/contact-us"
    }
  })} />

  <!-- Named slot for per-page head injections (schema, etc.) -->
  <slot name="head" />

  <style is:global>
    /* ──────────────────────────────────────
       COSMIC DESIGN TOKENS
    ────────────────────────────────────── */
    :root {
      --c-bg:           #0a0a0f;
      --c-bg-2:         #111119;
      --c-bg-3:         #1a1a28;
      --c-surface:      #16161f;
      --c-border:       rgba(255,255,255,0.07);
      --c-border-gold:  rgba(201,144,31,0.25);

      --c-text:         #eeeef2;
      --c-text-muted:   #b4b7cc;  /* was #8a8d9e — boosted for iPhone/mobile legibility */
      --c-text-faint:   #8a8da8;  /* was #4a4d62 — previously failed WCAG AA contrast */

      --c-gold:         #c9901f;
      --c-gold-light:   #e5af32;
      --c-gold-pale:    rgba(201,144,31,0.12);
      --c-silver:       #c8cdd6;
      --c-silver-pale:  rgba(200,205,214,0.08);

      --font-serif:     'Cormorant Garamond', Georgia, serif;
      --font-sans:      'DM Sans', system-ui, sans-serif;

      --radius-sm:      6px;
      --radius:         12px;
      --radius-lg:      20px;
      --radius-xl:      28px;
      --radius-full:    9999px;

      --shadow-card:    0 8px 32px rgba(0,0,0,0.45), 0 2px 8px rgba(0,0,0,0.3);
      --shadow-hover:   0 16px 48px rgba(0,0,0,0.55), 0 4px 16px rgba(201,144,31,0.12);
      --shadow-glow:    0 0 40px rgba(201,144,31,0.18);

      --dur-fast:       150ms;
      --dur-base:       250ms;
      --dur-slow:       450ms;
      --ease-smooth:    cubic-bezier(0.16, 1, 0.3, 1);
      --ease-bounce:    cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .light {
      --c-bg:           #f7f6f2;
      --c-bg-2:         #edeae0;
      --c-bg-3:         #e2ddd0;
      --c-surface:      #faf9f6;
      --c-border:       rgba(0,0,0,0.08);
      --c-border-gold:  rgba(160,100,30,0.25);
      --c-text:         #1a1a28;
      --c-text-muted:   #5a5e72;
      --c-text-faint:   #9295a8;
      --c-gold:         #a07030;
      --c-gold-light:   #c9901f;
      --c-gold-pale:    rgba(160,112,48,0.1);
      --c-silver:       #5a5e72;
      --c-silver-pale:  rgba(90,94,114,0.06);
      --shadow-card:    0 4px 24px rgba(0,0,0,0.1), 0 1px 4px rgba(0,0,0,0.06);
      --shadow-hover:   0 8px 32px rgba(0,0,0,0.15), 0 2px 8px rgba(160,112,48,0.1);
    }

    /* ──────────────────────────────────────
       RESETS & BASE
    ────────────────────────────────────── */
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
      -webkit-text-size-adjust: 100%;
      font-size: 16px;
    }

    body {
      font-family: var(--font-sans);
      background-color: var(--c-bg);
      color: var(--c-text);
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      overflow-x: hidden;
      transition: background-color 0.3s ease, color 0.3s ease;
      text-rendering: optimizeLegibility;
    }

    /* Boost mobile text contrast — small screens, especially iPhones on OLED,
       need slightly brighter muted text on very dark backgrounds */
    @media (max-width: 768px) {
      :root {
        --c-text-muted: #bdbfc9;
        --c-text-faint: #9597b0;
      }
    }

    /* ──────────────────────────────────────
       TYPOGRAPHY SYSTEM
    ────────────────────────────────────── */
    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-serif);
      font-weight: 400;
      line-height: 1.1;
      letter-spacing: -0.01em;
      color: var(--c-text);
    }

    h1 { font-size: clamp(2.4rem, 6vw, 5.5rem); letter-spacing: -0.02em; }
    h2 { font-size: clamp(1.8rem, 4vw, 3.5rem); }
    h3 { font-size: clamp(1.3rem, 2.5vw, 2.2rem); }
    h4 { font-size: clamp(1.1rem, 1.8vw, 1.6rem); }

    p {
      color: var(--c-text-muted);
      font-size: 1rem;
      line-height: 1.72;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    img {
      display: block;
      max-width: 100%;
      height: auto;
    }

    /* ──────────────────────────────────────
       UTILITY CLASSES
    ────────────────────────────────────── */
    .text-gold { color: var(--c-gold); }
    .text-silver { color: var(--c-silver); }
    .text-muted { color: var(--c-text-muted); }
    .text-faint { color: var(--c-text-faint); }

    .serif { font-family: var(--font-serif); }
    .sans { font-family: var(--font-sans); }

    .label {
      font-family: var(--font-sans);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--c-gold);
    }

    .section {
      padding: clamp(4rem, 8vw, 9rem) clamp(1.25rem, 4vw, 3rem);
    }

    .container {
      max-width: 1440px;
      margin: 0 auto;
      padding: 0 clamp(1.25rem, 4vw, 3rem);
    }

    .container-sm {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 clamp(1.25rem, 4vw, 2rem);
    }

    /* ──────────────────────────────────────
       SHIMMER EFFECT (WIDMANSTÄTTEN)
    ────────────────────────────────────── */
    .shimmer-text {
      background: linear-gradient(
        135deg,
        #eeeef2 0%,
        #e5af32 30%,
        #c8cdd6 50%,
        #e5af32 70%,
        #eeeef2 100%
      );
      background-size: 300% auto;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: shimmerText 4s ease-in-out infinite;
    }

    @keyframes shimmerText {
      0%, 100% { background-position: 0% center; }
      50% { background-position: 100% center; }
    }

    /* Crystal shimmer overlay on images */
    .shimmer-overlay {
      position: relative;
      overflow: hidden;
    }

    .shimmer-overlay::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        135deg,
        transparent 0%,
        rgba(201,144,31,0.08) 30%,
        rgba(200,205,214,0.12) 50%,
        rgba(201,144,31,0.08) 70%,
        transparent 100%
      );
      background-size: 300% 300%;
      opacity: 0;
      transition: opacity var(--dur-slow) var(--ease-smooth);
      pointer-events: none;
      animation: shimmerSweep 4s ease-in-out infinite;
    }

    .shimmer-overlay:hover::after {
      opacity: 1;
    }

    @keyframes shimmerSweep {
      0%, 100% { background-position: -100% -100%; }
      50% { background-position: 200% 200%; }
    }

    /* ──────────────────────────────────────
       CARD COMPONENT
    ────────────────────────────────────── */
    .card {
      background: var(--c-surface);
      border: 1px solid var(--c-border);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-card);
      transition:
        transform var(--dur-slow) var(--ease-smooth),
        box-shadow var(--dur-slow) var(--ease-smooth),
        border-color var(--dur-slow) var(--ease-smooth);
    }

    .card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-hover);
      border-color: var(--c-border-gold);
    }

    /* ──────────────────────────────────────
       BUTTON COMPONENTS
    ────────────────────────────────────── */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.875rem 2rem;
      border-radius: var(--radius-full);
      font-family: var(--font-sans);
      font-size: 0.8125rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      cursor: pointer;
      border: none;
      transition:
        transform var(--dur-base) var(--ease-bounce),
        box-shadow var(--dur-base) var(--ease-smooth),
        background-color var(--dur-base) ease;
      white-space: nowrap;
      text-decoration: none;
    }

    .btn:active { transform: scale(0.97); }

    .btn-primary {
      background: var(--c-gold);
      color: #0a0a0f;
    }

    .btn-primary:hover {
      background: var(--c-gold-light);
      box-shadow: 0 0 30px rgba(201,144,31,0.4);
      transform: translateY(-2px);
    }

    .btn-outline {
      background: transparent;
      color: var(--c-text);
      border: 1px solid var(--c-border);
    }

    .btn-outline:hover {
      border-color: var(--c-border-gold);
      color: var(--c-gold-light);
      transform: translateY(-2px);
    }

    .btn-ghost {
      background: transparent;
      color: var(--c-text-muted);
      padding: 0.5rem 1rem;
    }

    .btn-ghost:hover { color: var(--c-text); }

    /* ──────────────────────────────────────
       DIVIDER
    ────────────────────────────────────── */
    .divider {
      width: 100%;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--c-border-gold), transparent);
    }

    .divider-sm {
      width: 3rem;
      height: 1px;
      background: var(--c-gold);
    }

    /* ──────────────────────────────────────
       SCROLL REVEAL
    ────────────────────────────────────── */
    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition:
        opacity 0.8s var(--ease-smooth),
        transform 0.8s var(--ease-smooth);
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ──────────────────────────────────────
       WIDMANSTÄTTEN PATTERN (CSS)
    ────────────────────────────────────── */
    .wid-pattern {
      background-image:
        repeating-linear-gradient(
          15deg,
          transparent,
          transparent 18px,
          rgba(201,144,31,0.04) 18px,
          rgba(201,144,31,0.04) 19px
        ),
        repeating-linear-gradient(
          -15deg,
          transparent,
          transparent 24px,
          rgba(200,205,214,0.03) 24px,
          rgba(200,205,214,0.03) 25px
        ),
        repeating-linear-gradient(
          75deg,
          transparent,
          transparent 32px,
          rgba(201,144,31,0.025) 32px,
          rgba(201,144,31,0.025) 33px
        );
    }

    /* ──────────────────────────────────────
       FOCUS STYLES (A11y)
    ────────────────────────────────────── */
    :focus-visible {
      outline: 2px solid var(--c-gold);
      outline-offset: 3px;
      border-radius: 4px;
    }

    /* ──────────────────────────────────────
       SCROLLBAR
    ────────────────────────────────────── */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--c-bg); }
    ::-webkit-scrollbar-thumb {
      background: var(--c-bg-3);
      border-radius: 3px;
    }
    ::-webkit-scrollbar-thumb:hover { background: var(--c-text-faint); }

    /* ──────────────────────────────────────
       SELECTION
    ────────────────────────────────────── */
    ::selection {
      background: rgba(201,144,31,0.25);
      color: var(--c-text);
    }

    /* ──────────────────────────────────────
       STAR FIELD
    ────────────────────────────────────── */
    .star-field {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }

    .star {
      position: absolute;
      width: 1px;
      height: 1px;
      background: white;
      border-radius: 50%;
      animation: starTwinkle var(--dur) ease-in-out infinite;
    }

    @keyframes starTwinkle {
      0%, 100% { opacity: var(--opacity); }
      50% { opacity: 0.1; }
    }

    /* ──────────────────────────────────────
       PROSE (Blog)
    ────────────────────────────────────── */
    .prose {
      font-family: var(--font-sans);
      color: var(--c-text-muted);
      line-height: 1.78;
      font-size: 1.0625rem;
    }

    .prose h2 {
      font-family: var(--font-serif);
      font-size: clamp(1.5rem, 3vw, 2.2rem);
      color: var(--c-text);
      margin: 3rem 0 1.25rem;
      font-weight: 400;
      letter-spacing: -0.01em;
    }

    .prose h3 {
      font-family: var(--font-sans);
      font-size: 1.125rem;
      font-weight: 600;
      color: var(--c-text);
      margin: 2rem 0 0.75rem;
      letter-spacing: 0;
    }

    .prose p {
      margin: 0 0 1.5rem;
      font-size: 1.0625rem;
    }

    .prose strong {
      color: var(--c-text);
      font-weight: 600;
    }

    .prose ul, .prose ol {
      padding-left: 1.5rem;
      margin: 0 0 1.5rem;
    }

    .prose li { margin: 0.5rem 0; }

    .prose em {
      font-style: italic;
      color: var(--c-text);
    }

    .prose hr {
      border: none;
      border-top: 1px solid var(--c-border-gold);
      margin: 3rem 0;
    }

    .prose blockquote {
      border-left: 3px solid var(--c-gold);
      padding-left: 1.5rem;
      margin: 2rem 0;
      font-style: italic;
      font-family: var(--font-serif);
      font-size: 1.2rem;
      color: var(--c-text);
    }
  </style>

  <!-- Inline theme init: runs before first paint to prevent flash of wrong theme -->
  <script is:inline>
    (function() {
      var saved = localStorage.getItem('mjTheme');
      if (saved === 'light') {
        document.documentElement.classList.remove('dark');
        document.documentElement.classList.add('light');
      }
    })();
  </script>
</head>
<body class="wid-pattern">
  <!-- Scroll reveal -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    });
  </script>

  <slot />
</body>
</html>