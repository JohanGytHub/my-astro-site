---
const year = new Date().getFullYear();
---

<footer class="footer">
  <!-- Main store redirect banner -->
  <div class="footer-banner">
    <div class="container">
      <div class="banner-inner">
        <div class="banner-text">
          <span class="label">Complete Your Purchase</span>
