      <!-- Bottom bar -->
      <div class="footer-bottom">
        <div class="footer-disclaimer-note">
          This site contains AI-assisted content. Information may contain errors.
          <a href="/disclaimer">Report an inaccuracy →</a>
        </div>
        <div class="footer-bottom-row">
          <p class="footer-copy">© {year} Jewelry by Johan. All rights reserved. Site by meteorite.jewelry.</p>
          <div class="footer-legal">
            <a href="https://jewelrybyjohan.com/policies/privacy-policy" target="_blank" rel="noopener">Privacy</a>
            <a href="https://jewelrybyjohan.com/policies/terms-of-service" target="_blank" rel="noopener">Terms</a>
            <a href="/return-policy">Returns</a>
            <a href="/disclaimer">Disclaimer</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--c-border);
    margin-top: 6rem;
  }

  /* Banner */
  .footer-banner {
    background: var(--c-bg-2);
    border-bottom: 1px solid var(--c-border);
    padding: 3.5rem clamp(1.25rem, 4vw, 2rem);
  }

  .banner-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .banner-heading {
    font-size: clamp(1.4rem, 3vw, 2rem);
    color: var(--c-text);
    margin: 0.25rem 0 0.5rem;
    line-height: 1.2;
    font-family: var(--font-serif);
  }

  .banner-sub {
    font-size: 0.9rem;
    color: var(--c-text-muted);
    max-width: 480px;
    margin: 0;
  }

  .banner-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* Body */
  .footer-body {
    padding: 4rem 0 0;
    background: var(--c-bg);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--c-border);
  }

  /* Brand */
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--c-gold);
    margin-bottom: 1rem;
    text-decoration: none;
  }

  .footer-logo-text {
    font-size: 1.125rem;
    color: var(--c-text);
  }

  .footer-tagline {
    font-size: 0.875rem;
    color: var(--c-text-muted);
    line-height: 1.65;
    margin-bottom: 1.5rem;
    max-width: 280px;
  }

  .footer-social {
    display: flex;
    gap: 0.75rem;
  }

  .social-link {
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--c-border);
    border-radius: var(--radius-full);
    color: var(--c-text-muted);
    transition: color 0.2s, border-color 0.2s;
  }

  .social-link:hover {
    color: var(--c-gold);
    border-color: var(--c-border-gold);
  }

  /* Columns */
  .footer-col-title {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-text);
    margin-bottom: 1.25rem;
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer-links a {
    font-size: 0.875rem;
    color: var(--c-text-muted);
    transition: color 0.2s, padding-left 0.2s;
  }

  .footer-links a:hover {
    color: var(--c-text);
    padding-left: 4px;
  }

  /* Trust */
  .footer-trust {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    padding: 2rem 0;
    border-bottom: 1px solid var(--c-border);
    justify-content: center;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--c-text-muted);
    font-size: 0.8125rem;
  }

  .trust-item svg { color: var(--c-gold); }

  /* Bottom */
  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem 0;
  }

  .footer-disclaimer-note {
    font-size: 0.75rem;
    color: var(--c-text-faint);
    text-align: center;
    padding: 0.5rem 0;
  }

  .footer-disclaimer-note a {
    color: var(--c-text-faint);
    text-decoration: underline;
    text-underline-offset: 3px;
    margin-left: 0.375rem;
    transition: color 0.2s;
  }

  .footer-disclaimer-note a:hover { color: var(--c-text-muted); }

  .footer-bottom-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-copy {
    font-size: 0.8125rem;
    color: var(--c-text-faint);
    margin: 0;
  }

  .footer-legal {
    display: flex;
    gap: 1.5rem;
  }

  .footer-legal a {
    font-size: 0.8125rem;
    color: var(--c-text-faint);
    transition: color 0.2s;
  }

  .footer-legal a:hover { color: var(--c-text-muted); }

  /* Responsive */
  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .banner-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .footer-trust {
      gap: 1rem;
    }

    .footer-bottom-row {
      flex-direction: column;
      text-align: center;
    }
  }
</style>